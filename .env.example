# SERVER-ONLY environment variables (set in Netlify dashboard, never use VITE_ prefix)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
DISCOUNT_CODE=YOURCODE

# EMAIL (server-only)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=...
# Admin email receives a CC on every order confirmation
# (hardcoded in send-email.js — update there if you change it)

# GOOGLE SHEETS (server-only)
# Paste the full JSON contents of your service account key file as a single-line string
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS={"type":"service_account",...}
GOOGLE_SPREADSHEET_ID=...

# FRONTEND variables (VITE_ prefix = bundled into browser JS — keep non-secret only)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
